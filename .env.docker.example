# Copy to .env for containerized local run and fill real API keys.
FLASK_ENV=production
SECRET_KEY=change-me

# Local Docker stack endpoints
DATABASE_URL=postgresql+psycopg://telegram:telegram@postgres:5432/telegram_automation
REDIS_URL=redis://redis:6379/0

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Telegram
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_hash
TELEGRAM_PHONE=+10000000000
TELEGRAM_SESSION_STRING=
TELEGRAM_TARGET_CHANNEL=@your_channel

# Optional initial admin creation (handled in wsgi.py)
INIT_ADMIN_USER=admin
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=change-me-strong
